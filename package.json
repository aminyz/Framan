{
  "name": "minddock",
  "version": "1.0.0",
  "description": "MindDock — پلتفرم مدیریت بهره‌وری شخصی",
  "main": "src/main.js",
  "author": "aminyz",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.minddock.app",
    "productName": "MindDock",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": ["fa-IR", "en-US"],
      "language": "1065"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
